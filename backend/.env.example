# ── Server ────────────────────────────────────────────────────────────────
# Port the Express server listens on (Render injects its own PORT in production)
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev: http://localhost:3000 — Production: your Vercel URL only.
ALLOWED_ORIGIN=http://localhost:3000

# ── Access gate ───────────────────────────────────────────────────────────
# Shared password required on every /api request (x-access-password header).
# The frontend asks for it once and stores it in the browser.
ACCESS_PASSWORD=

# ── Supabase (Project Settings → API) ─────────────────────────────────────
# Project URL, e.g. https://xxxx.supabase.co
SUPABASE_URL=
# service_role key — server-side only, bypasses RLS. NEVER expose to the frontend.
SUPABASE_SERVICE_ROLE_KEY=

# ── Groq (console.groq.com) ───────────────────────────────────────────────
# Used for groq/compound (web-search grounding) and openai/gpt-oss-120b (extraction pass A)
GROQ_API_KEY=

# ── Google AI Studio (aistudio.google.com) ────────────────────────────────
# Used for gemini-3.5-flash: grounded extraction pass B + final reconciliation
GEMINI_API_KEY=

# ── Firecrawl (firecrawl.dev) ─────────────────────────────────────────────
# Site scraping: home / about / contact / team pages
FIRECRAWL_API_KEY=

# ── Google Custom Search (optional) ───────────────────────────────────────
# Extra LinkedIn/domain lookups. Leave empty to skip — the pipeline already
# covers this via Groq Compound search + Gemini grounding.
GOOGLE_CSE_KEY=
GOOGLE_CSE_ID=
